GB_ENV=dev
GB_CONFIG_PATH=configs/config.yaml
GB_ZONES_PATH=configs/zones.yaml
GB_DB_PATH=data/events/guardian_baby.db
GB_SNAPSHOTS_DIR=data/snapshots
GB_NOTIFICATIONS_DRY_RUN=true
GB_LOG_LEVEL=INFO
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
OPENAI_TIMEOUT_SECONDS=10
OPENAI_MAX_RETRIES=2
OPENAI_ENABLE_SUMMARIZATION=true
ENABLE_FRAME_LLM_ANALYSIS=true
FRAME_STORAGE_DIR=data/frames/current_batch
FRAME_BATCH_SIZE=240
FRAME_QUEUE_MAX_SIZE=200
FRAME_QUEUE_OVERFLOW_STRATEGY=drop_oldest
GB_INGEST_MODE=mqtt
MQTT_HOST=<wifi_ip>
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_MAX_PENDING_PAIRS=500
