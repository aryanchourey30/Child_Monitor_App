GB_ENV=dev
GB_CONFIG_PATH=configs/config.yaml
GB_ZONES_PATH=configs/zones.yaml
GB_DB_PATH=data/events/guardian_baby.db
GB_SNAPSHOTS_DIR=data/snapshots
GB_NOTIFICATIONS_DRY_RUN=true
GB_LOG_LEVEL=INFO
OPENAI_API_KEY= "<OpenAI_API_Key>"
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=8
OPENAI_ENABLE_SUMMARIZATION=true
